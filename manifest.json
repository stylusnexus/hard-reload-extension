{
  "manifest_version": 3,
  "name": "Hard Reload",
  "version": "1.0.0",
  "description": "One-click hard reload with optional browser storage clearing. Useful to quickly refresh cached assets during dev work.",
  "permissions": ["tabs", "browsingData", "scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "hard-reload": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Hard reload the current tab"
    }
  }
}
